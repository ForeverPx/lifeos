{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "lifeos (Chrome, secrets file)",
      "request": "launch",
      "type": "dart",
      "program": "lib/main.dart",
      "toolArgs": [
        "-d",
        "chrome",
        "--web-port=8080",
        "--dart-define-from-file=dart_defines/local.json"
      ]
    },
    {
      "name": "lifeos (Chrome, no secrets file)",
      "request": "launch",
      "type": "dart",
      "program": "lib/main.dart",
      "toolArgs": ["-d", "chrome", "--web-port=8080"]
    }
  ]
}
